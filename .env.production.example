# Copy this to .env on the server and fill in the values.

POSTGRES_DB=screenings
POSTGRES_USER=postgres
POSTGRES_PASSWORD=           # generate with: openssl rand -base64 32

# Must match the values above
DATABASE_URL=postgresql+asyncpg://postgres:YOURPASSWORD@db:5432/screenings

GOOGLE_PLACES_API_KEY=       # from Google Cloud Console

NEXT_PUBLIC_API_URL=https://api.whats-screening-to.ca

SCRAPE_INTERVAL_HOURS=12
